worker1: go run . leader --dev-mode --raft.node-host-dir=/tmp/armada-cluster/leader-1/raft --raft.state-machine-dir=/tmp/armada-cluster/leader-1/state-machine --raft.address=127.0.0.1:5000 --raft.initial-members='127.0.0.1:5000,127.0.0.1:5100,127.0.0.1:5200' --tables.names=armada-test --api.address=http://0.0.0.0:5001 --api.advertise-address=http://127.0.0.1:5001 --rest.address=http://127.0.0.1:5010 --replication.address=https://127.0.0.1:5002 --replication.ca-filename=hack/replication/ca.crt --replication.cert-filename=hack/replication/server.crt --replication.key-filename=hack/replication/server.key --shared-store.backend=filesystem --shared-store.filesystem.directory='/tmp/armada-cluster/shared-store' --shared-store.gc-interval=30s --shared-store.retention=1h
