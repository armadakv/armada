worker1: go run . leader --dev-mode --raft.node-host-dir=/tmp/regatta-1/raft --raft.state-machine-dir=/tmp/regatta-1/stable --raft.address=127.0.0.1:${PORT} --raft.initial-members='127.0.0.1:5000,127.0.0.1:5100,127.0.0.1:5200' --tables.names=regatta-test --api.address=http://0.0.0.0:$(expr $PORT + 1) --api.advertise-address=http://127.0.0.1:$(expr $PORT + 1) --rest.address=http://127.0.0.1:$(expr $PORT + 10)  --maintenance.enabled=false --replication.enabled=false
